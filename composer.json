{
    "name": "hermex/sistema",
    "description": "HermeX - Sistema de Monitoramento de Cadeia de Custódia de Cargas",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "mongodb/mongodb": "^2.0",
        "mpdf/mpdf": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "config/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
